{
  "KKACHI_AGENT_BRIDGE_MANAGED": "true",
  "KKACHI_AGENT_BRIDGE_ID": "default",
  "KKACHI_AGENT_BRIDGE_CONFIG": "/Users/draccoon/.hermes/profiles/jangbi/home/.config/kkachi-agent-bridge/config.yaml",
  "bridge_base_url": "http://localhost:9876",
  "settings_file": "/Users/draccoon/Workspace/SeventeenthEarth/kkachi/kkachi-agent-network-plugin/.claude/settings.local.json",
  "managed_event_keys": [
    "Notification",
    "PermissionRequest",
    "PostToolUse",
    "PostToolUseFailure",
    "PreToolUse",
    "SessionEnd",
    "SessionStart",
    "Stop",
    "StopFailure",
    "UserPromptSubmit"
  ],
  "managed_extra_keys": [
    "enabledPlugins"
  ],
  "managed_matchers": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/permission",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/post-tool-use"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/tool-failed"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/pre-tool-use/ask",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/pre-tool-use"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/session-end"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:9876/hook/session-start -H 'Content-Type: application/json' -d @-"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/stop-failure"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/prompt-submitted"
          }
        ]
      }
    ]
  }
}
