{
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "codex@openai-codex": false,
    "document-skills@anthropic-agent-skills": false,
    "frontend-design@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "octo@nyldn-plugins": false,
    "oh-my-claudecode@omc": false,
    "swift-lsp@claude-plugins-official": false,
    "telegram@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "understand-anything@understand-anything": false
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/permission",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/post-tool-use"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/tool-failed"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/pre-tool-use/ask",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/pre-tool-use"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/session-end"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:9876/hook/session-start -H 'Content-Type: application/json' -d @-"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/stop-failure"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9876/hook/prompt-submitted"
          }
        ]
      }
    ]
  }
}
